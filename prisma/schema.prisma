generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
 
}

model Question {
  id       Int    @id @default(autoincrement())
  question String
  optionA  String
  optionB  String
  optionC  String
  optionD  String
  answer   String
}

model Score {
  id    Int    @id @default(autoincrement())
  name  String
  score Int
}